{
  "name": "@novelloom/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node -e \"console.log('[novelloom] server dev script started')\" && node --watch --import tsx src/index.ts",
    "dev:run": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.48",
    "@fastify/cors": "^10.0.1",
    "@novelloom/shared": "workspace:*",
    "@openai/agents": "^0.0.5",
    "ai": "^6.0.199",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "openai": "^5.23.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
