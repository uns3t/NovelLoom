# Required for AI features: OpenAI-compatible API key.
# Book management and local project file APIs can start without this value.
LLM_API_KEY=

# Optional: model provider name shown in runtime diagnostics.
# Supported examples: deepseek, opencode, openrouter.
LLM_PROVIDER=deepseek

# Optional: model service base URL. Do not include /chat/completions.
# DeepSeek: https://api.deepseek.com
# opencode: https://opencode.ai/zen/go/v1
# OpenRouter: https://openrouter.ai/api/v1
LLM_BASE_URL=https://api.deepseek.com

# Optional: legacy DeepSeek variables are still supported as fallback.
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional: backend server port.
PORT=8097

# Optional: backend listen host.
# Use localhost by default for Windows compatibility. If needed, use 127.0.0.1 or 0.0.0.0.
HOST=localhost

# Optional: host used by the frontend Vite proxy to reach the backend.
# Defaults to HOST when empty.
BACKEND_HOST=localhost

# Optional: frontend Vite dev/preview server port.
WEB_PORT=3077

# Optional: model name. For opencode/openrouter, set this to a model name supported by that endpoint.
MODEL=deepseek-v4-pro

# Optional: local book data directory, relative to repo root or absolute.
BOOKS_DIR=data/books
